# MongoDB (required for auth + history APIs)
MONGODB_URI=mongodb://127.0.0.1:27017/ui-code-generator

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth (optional — omit to hide buttons; credentials login still works)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Email for password reset (optional — dev logs link to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Footer WhatsApp (digits only, country code included, e.g. 923001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# OpenAI (existing app)
OPENAI_API_KEY=
